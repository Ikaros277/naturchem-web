# Google Analytics 4 – po nasazení doplnit v nastavení Vercel
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Maps – volitelné: plná mapa se 3 špendlíky najednou (Maps JavaScript API).
# Bez klíče web používá interaktivní OpenStreetMap mapu (posuv, zoom, 3 špendlíky) — zdarma.
# Nastavení klíče: https://console.cloud.google.com/google/maps-apis/start
#
# Ochrana proti zneužití (DŮLEŽITÉ po vytvoření klíče):
# 1) Credentials → váš klíč → Application restrictions: HTTP referrers
#    Povolené: https://www.naturchem.cz/*  https://naturchem.cz/*
#    (volitelně staging: https://web-naturchem.vercel.app/*)
# 2) API restrictions: pouze „Maps JavaScript API“
# 3) APIs & Services → Quotas → Maps JavaScript API → nastavit denní limit (např. 500/den)
# 4) Billing → Budgets & alerts → upozornění např. při 500 Kč / měsíc
#
# Cena: do cca 10 000 zobrazení mapy/měsíc zdarma; pro běžný firemní web typicky 0 Kč.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Volitelné marketingové tagy – načtou se až po souhlasu s marketingovými cookies
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# --- Live chat (Tawk.to) + WhatsApp ---
# WhatsApp tlačítko: ve výchozím stavu zapnuto, číslo +420 736 778 391.
# NEXT_PUBLIC_WHATSAPP_ENABLED=false
# NEXT_PUBLIC_WHATSAPP_PHONE=420736778391
#
# Tawk.to widget (načte se po volbě v cookie liště).
# Výchozí ID z embed kódu na tawk.to — lze přepsat env proměnnými.
NEXT_PUBLIC_TAWK_PROPERTY_ID=6a31575716fcef1d436f9b31
NEXT_PUBLIC_TAWK_WIDGET_ID=1jr8bqc1t
# NEXT_PUBLIC_TAWK_ENABLED=false

# --- Decap CMS (/admin) – GitHub OAuth ---
# Veřejná URL webu (musí odpovídat doméně, na které otevíráte /admin)
# Staging: https://web-naturchem.vercel.app | produkce: https://www.naturchem.cz
NEXT_PUBLIC_SITE_URL=https://web-naturchem.vercel.app
# GitHub OAuth App: Settings → Developer settings → OAuth Apps
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# --- Kontaktní formulář (Resend) ---
# API klíč: https://resend.com/api-keys — bez něj se e-mail neodešle (fallback jen log + zpráva uživateli).
RESEND_API_KEY=

# Odesílatel — po ověření domény v Resend např. naturchem@naturchem.cz
# Pro rychlý test lze dočasně použít onboarding@resend.dev (omezení viz dokumentace Resend).
CONTACT_FROM_EMAIL=

# Příjemci poptávek (čárkou oddělené). Pokud prázdné, použijí se výchozí adresy z kódu (site).
CONTACT_TO_EMAILS=

# Příjemci dotazníku spokojenosti (čárkou oddělené). Pokud prázdné, použijí se výchozí adresy z kódu.
SATISFACTION_TO_EMAILS=
